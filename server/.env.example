# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# MongoDB connection string (Atlas or local).
# Not required when running `npm run dev:memory` (uses an in-memory DB).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Long random string used to sign JWTs. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Port the API listens on.
PORT=5000

# Firebase Admin service-account JSON path (only needed for social login).
# Download from Firebase Console > Project Settings > Service Accounts.
# Keep this file out of git (already gitignored).
# FIREBASE_SERVICE_ACCOUNT=./config/your-service-account.json
