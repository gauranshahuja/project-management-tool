# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# MongoDB connection string (Atlas or local).
# Not required when running `npm run dev:memory` (uses an in-memory DB).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Long random string used to sign JWTs. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Port the API listens on.
PORT=5000

# Firebase Admin service-account JSON path (only needed for social login).
# Download from Firebase Console > Project Settings > Service Accounts.
# Keep this file out of git (already gitignored).
# FIREBASE_SERVICE_ACCOUNT=./config/your-service-account.json

# App URL used in email links (where the frontend is hosted).
APP_URL=http://localhost:5173

# Email (optional). If unset, emails are skipped and just logged in dev.
# Works with Gmail app-password, Mailtrap, SendGrid SMTP, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=ProjectHub <you@gmail.com>
