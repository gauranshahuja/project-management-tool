# API base (proxied to the server)
VITE_API_BASE_URL=/api

# Firebase Web config — get these from your Firebase project settings
# (Project settings → General → Your apps → Web app → SDK config).
# These are public client identifiers; keep your real .env out of git.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
